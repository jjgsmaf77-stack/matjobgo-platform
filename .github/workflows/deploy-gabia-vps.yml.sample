name: Deploy to Gabia (매잡고 플랫폼)

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"

      - name: Install dependencies
        run: npm ci

      - name: Generate Prisma client
        run: npx prisma generate

      - name: Build Next.js
        run: npm run build
        env:
          NODE_ENV: production
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
          NEXTAUTH_SECRET: ${{ secrets.NEXTAUTH_SECRET }}
          NEXTAUTH_URL: ${{ secrets.NEXTAUTH_URL }}

      - name: Create deploy archive
        run: |
          tar czf deploy.tar.gz \
            .next \
            public \
            node_modules \
            package.json \
            package-lock.json \
            prisma \
            prisma.config.ts \
            next.config.ts \
            ecosystem.config.js

      - name: Copy to Gabia server
        uses: appleboy/scp-action@v0.1.7
        with:
          host: ${{ secrets.GABIA_HOST }}
          username: ${{ secrets.GABIA_USER }}
          key: ${{ secrets.GABIA_SSH_KEY }}
          port: ${{ secrets.GABIA_PORT }}
          source: "deploy.tar.gz"
          target: "/tmp"

      - name: Deploy on Gabia server
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.GABIA_HOST }}
          username: ${{ secrets.GABIA_USER }}
          key: ${{ secrets.GABIA_SSH_KEY }}
          port: ${{ secrets.GABIA_PORT }}
          script: |
            set -e
            APP_DIR=/var/www/matjobgo-platform
            BACKUP_DIR=/var/www/matjobgo-platform.bak

            # 백업
            if [ -d "$APP_DIR" ]; then
              sudo rm -rf $BACKUP_DIR
              sudo cp -r $APP_DIR $BACKUP_DIR
            fi

            # 해제
            sudo mkdir -p $APP_DIR
            sudo tar xzf /tmp/deploy.tar.gz -C $APP_DIR
            sudo chown -R $USER:$USER $APP_DIR
            rm /tmp/deploy.tar.gz

            # Prisma 마이그레이션 (최초 또는 스키마 변경시)
            cd $APP_DIR
            npx prisma migrate deploy

            # PM2 재시작 (없으면 기동)
            if pm2 describe matjobgo > /dev/null 2>&1; then
              pm2 reload ecosystem.config.js --env production
            else
              pm2 start ecosystem.config.js --env production
              pm2 save
            fi

            echo "✅ 배포 완료 · $(date)"
